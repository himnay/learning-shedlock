<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot default base configuration (console + file from application.yml) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="APP_NAME"  source="spring.application.name"  defaultValue="learning-shedlock"/>
    <springProperty scope="context" name="LOG_PATH"  source="logging.file.path"         defaultValue="logs"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root"         defaultValue="INFO"/>

    <!-- ── Console Appender ───────────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Rolling File Appender ──────────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Package-level log levels ───────────────────────────────────────── -->
    <logger name="com.org.shedlock"                          level="DEBUG"/>
    <logger name="net.javacrumbs.shedlock"                  level="DEBUG"/>
    <logger name="org.springframework.scheduling"           level="DEBUG"/>
    <logger name="org.flywaydb"                             level="INFO"/>
    <logger name="org.springframework.jdbc"                 level="WARN"/>
    <logger name="com.zaxxer.hikari"                        level="WARN"/>

    <!-- ── local profile — verbose console, no file ───────────────────────── -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── test profile — console only, reduce noise ─────────────────────── -->
    <springProfile name="test">
        <logger name="net.javacrumbs.shedlock" level="INFO"/>
        <logger name="org.springframework.scheduling" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── default (dev / prod) — console + rolling file ─────────────────── -->
    <springProfile name="!local &amp; !test">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>
